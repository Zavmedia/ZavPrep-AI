# === ACCESS CONTROL ===
# Comma-separated access codes you give to students
APP_ACCESS_CODES=Dream_100%

# Password all students must also enter (shared)
APP_PASSWORD=Success@hardwork%

# Admin panel password (only you know this)
ADMIN_CODE=youradminpassword

# === FIREBASE (Student Memory) ===
FIREBASE_PROJECT_ID=zavprep
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@zavprep.iam.gserviceaccount.com
# Paste your private key exactly as it appears in the JSON file
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# === AI PROVIDERS ===
# OpenRouter key (free Gemma model) - get from openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# Anthropic Claude key (optional, premium)
# ANTHROPIC_API_KEY=sk-ant-...

# === APP CONFIG ===
APP_BASE_URL=https://your-project.vercel.app
APP_RATE_LIMIT_PER_HOUR=80
